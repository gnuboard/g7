{
  "meta": {
    "is_partial": true,
    "description": "플러그인 재활성화 후 cascade 비활성화됐던 언어팩 일괄 활성화 확인 모달 (요구사항 #7)"
  },
  "id": "plugin_reactivate_language_packs_modal",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:admin.plugins.modals.reactivate_language_packs_title",
    "size": "small"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "py-2"
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-600 dark:text-gray-400 mb-3"
          },
          "text": "$t:admin.plugins.modals.reactivate_language_packs_message"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "iteration": {
                "source": "_global.reactivateLanguagePacksData ?? []",
                "item_var": "pack"
              },
              "props": {
                "className": "flex items-center gap-2 p-2 bg-gray-50 dark:bg-gray-700/50 rounded"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "language",
                    "className": "w-4 h-4 text-gray-500 dark:text-gray-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-700 dark:text-gray-300 font-medium"
                  },
                  "text": "{{pack.locale_native_name}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs text-gray-500 dark:text-gray-400"
                  },
                  "text": "({{pack.locale}})"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isBulkActivatingLanguagePacks}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "reactivateLanguagePacksData": null
                  }
                },
                {
                  "handler": "closeModal"
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.skip"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "flex items-center gap-2 px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 disabled:opacity-50 disabled:cursor-not-allowed",
            "disabled": "{{_global.isBulkActivatingLanguagePacks}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                {
                  "handler": "setState",
                  "params": {
                    "target": "global",
                    "isBulkActivatingLanguagePacks": true
                  }
                },
                {
                  "handler": "apiCall",
                  "auth_required": true,
                  "target": "/api/admin/language-packs/bulk-activate",
                  "params": {
                    "method": "POST",
                    "body": {
                      "ids": "{{_global.reactivateLanguagePacksData?.map(p => p.id) ?? []}}"
                    }
                  },
                  "onSuccess": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isBulkActivatingLanguagePacks": false,
                        "reactivateLanguagePacksData": null
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "message": "$t:admin.plugins.modals.reactivate_language_packs_success",
                        "type": "success"
                      }
                    },
                    {
                      "handler": "closeModal"
                    }
                  ],
                  "onError": [
                    {
                      "handler": "setState",
                      "params": {
                        "target": "global",
                        "isBulkActivatingLanguagePacks": false
                      }
                    },
                    {
                      "handler": "toast",
                      "params": {
                        "message": "$t:admin.plugins.modals.reactivate_language_packs_failed",
                        "type": "error"
                      }
                    }
                  ]
                }
              ]
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.activate"
            }
          ]
        }
      ]
    }
  ]
}
