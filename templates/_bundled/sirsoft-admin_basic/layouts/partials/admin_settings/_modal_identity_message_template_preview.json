{
  "meta": {
    "is_partial": true,
    "description": "IDV 메시지 템플릿 미리보기 모달 — 변수 치환 결과 (subject/body) 렌더링"
  },
  "id": "modal_identity_message_template_preview",
  "type": "composite",
  "name": "Modal",
  "props": {
    "id": "modal_identity_message_template_preview",
    "size": "lg",
    "title": "$t:admin.settings.identity.messages.modal.preview"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": { "className": "space-y-4 p-4" },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1" },
              "text": "$t:admin.settings.identity.messages.modal.subject_label"
            },
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" },
              "text": "{{_global.identity_message_template_preview_modal?.subject ?? ''}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "rounded-md border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2" },
              "text": "$t:admin.settings.identity.messages.modal.body_label"
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "prose prose-sm max-w-none dark:prose-invert",
                "innerHTML": "{{_global.identity_message_template_preview_modal?.body ?? ''}}"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": { "className": "flex justify-end pt-3 border-t border-gray-200 dark:border-gray-700" },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "px-3 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-50 dark:hover:bg-gray-700"
              },
              "text": "$t:admin.common.close",
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal",
                  "target": "modal_identity_message_template_preview"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
