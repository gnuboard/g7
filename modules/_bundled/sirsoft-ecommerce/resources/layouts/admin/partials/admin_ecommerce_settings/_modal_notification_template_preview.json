{
  "meta": {
    "is_partial": true,
    "description": "이커머스 메일 템플릿 미리보기 모달"
  },
  "id": "modal_ecommerce_notification_definition_preview",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.preview_modal.title",
    "size": "lg"
  },
  "children": [
    {
      "id": "ecommerce_preview_content",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-4"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "text": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.preview_modal.rendered_subject"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-900 rounded-md p-3 border border-gray-200 dark:border-gray-700"
              },
              "text": "{{$parent._local.previewData?.subject ?? ''}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": {
                "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
              },
              "text": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.preview_modal.rendered_body"
            },
            {
              "type": "composite",
              "name": "HtmlContent",
              "props": {
                "content": "{{$parent._local.previewData?.body ?? ''}}",
                "isHtml": true,
                "className": "prose dark:prose-invert prose-sm max-w-none bg-white dark:bg-gray-900 rounded-md p-4 border border-gray-200 dark:border-gray-700 max-h-[400px] overflow-y-auto"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end pt-4 border-t border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "id": "ecommerce_btn_close_preview",
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "text-sm px-4 py-2 rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors"
              },
              "text": "$t:sirsoft-ecommerce.admin.settings.notification_definitions.preview_modal.btn_close",
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal",
                  "target": "modal_ecommerce_notification_definition_preview"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
