                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "{{'language_currency.currencies.' + currency._idx + '.rounding_unit'}}",
                    "value": "{{currency.rounding_unit}}",
                    "options": "{{currency.code === 'KRW' || currency.code === 'JPY' ? [{ value: '1', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.1') }, { value: '10', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.10') }, { value: '100', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.100') }] : [{ value: '0.01', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.0_01') }, { value: '0.1', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.0_1') }, { value: '1', label: $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.1') }]}}",
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_method"
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "{{'language_currency.currencies.' + currency._idx + '.rounding_method'}}",
                    "value": "{{currency.rounding_method}}",
                    "options": [
                      {
                        "value": "floor",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.floor"
                      },
                      {
                        "value": "round",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.round"
                      },
                      {
                        "value": "ceil",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.ceil"
                      }
                    ],
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.decimal_places"
