                          "if": "{{!(_local.form?.newCurrency?.code?.trim() && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.form?.newCurrency?.code || '').toUpperCase().trim())) && _local.form?.newCurrency?.code?.trim()}}",
                          "params": {
                            "target": "local",
                            "form.language_currency.currencies": "{{[...(Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []), { code: (_local.form?.newCurrency?.code || '').toUpperCase().trim(), name: _local.form?.newCurrency?.name ?? {}, exchange_rate: _local.form?.newCurrency?.exchange_rate ?? 1, rounding_unit: _local.form?.newCurrency?.rounding_unit ?? '0.01', rounding_method: _local.form?.newCurrency?.rounding_method ?? 'round', is_default: false }]}}",
