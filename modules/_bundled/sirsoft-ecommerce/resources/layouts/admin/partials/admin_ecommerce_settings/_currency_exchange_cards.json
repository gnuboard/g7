                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "{{currency.code === (_local.form?.language_currency?.default_currency ?? 'KRW') ? 'btn-icon text-gray-300 cursor-not-allowed' : 'btn-icon text-error'}} disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_computed.isReadOnly || currency.code === (_local.form?.language_currency?.default_currency ?? 'KRW')}}"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "form.language_currency.currencies": "{{(Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).filter((c, i) => i !== currency._idx)}}",
                        "hasChanges": true
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "trash",
                        "className": "w-4 h-4"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.editingCurrencyIdx === currency._idx}}",
              "props": {
                "className": "flex items-center gap-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "btn-icon text-green-600 dark:text-green-400 hover:text-green-700 disabled:opacity-50 disabled:cursor-not-allowed",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "toast",
                          "if": "{{_local.editingCurrency?.code?.trim() && (_local.editingCurrency?.code?.toUpperCase().trim() !== _local.editingCurrency?.originalCode) && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.editingCurrency?.code || '').toUpperCase().trim())}}",
                          "params": {
                            "type": "error",
                            "message": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.duplicate_currency_error"
                          }
                        },
                        {
                          "handler": "setState",
                          "if": "{{_local.editingCurrency?.code?.trim() && (_local.editingCurrency?.code?.toUpperCase().trim() !== _local.editingCurrency?.originalCode) && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.editingCurrency?.code || '').toUpperCase().trim())}}",
                          "params": {
                            "target": "local",
                            "editingCurrency.hasError": true
                          }
                        },
                        {
                          "handler": "setState",
                          "if": "{{_local.editingCurrency?.code?.trim() && !(_local.editingCurrency?.code?.toUpperCase().trim() !== _local.editingCurrency?.originalCode && (Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).some(c => (c.code || '').toUpperCase() === (_local.editingCurrency?.code || '').toUpperCase().trim()))}}",
                          "params": {
                            "target": "local",
                            "form.language_currency.currencies": "{{(Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).map((c, i) => i === _local.editingCurrencyIdx ? { ...c, code: (_local.editingCurrency?.code || '').toUpperCase().trim(), name: _local.form?.editingCurrency?.name ?? _local.editingCurrency?.name ?? c.name } : c)}}",
                            "editingCurrencyIdx": null,
                            "editingCurrency": null,
                            "form.editingCurrency": null,
                            "hasChanges": true
                          }
                        }
                      ]
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "check",
                        "className": "w-5 h-5"
                      }
                    }
