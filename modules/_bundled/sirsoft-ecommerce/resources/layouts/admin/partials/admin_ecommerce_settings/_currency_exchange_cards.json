{
  "meta": {
    "is_partial": true,
    "description": "환율 설정 - Mobile 카드 뷰"
  },
  "id": "exchange_cards_container",
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "space-y-4"
  },
  "children": [
    {
      "id": "currency_card",
      "type": "basic",
      "name": "Div",
      "iteration": {
        "source": "(Array.isArray(_local.form?.language_currency?.currencies) ? _local.form.language_currency.currencies : []).map((c, i) => ({...c, _idx: i})).sort((a, b) => { const defaultCurrency = _local.form?.language_currency?.default_currency ?? 'KRW'; if (a.code === defaultCurrency) return -1; if (b.code === defaultCurrency) return 1; return 0; })",
        "item_var": "currency",
        "index_var": "currencyIndex"
      },
      "props": {
        "className": "excel-card"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "excel-card-header"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.editingCurrencyIdx !== currency._idx}}",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "{{'fi fi-' + (_defines?.currencyToFlag?.[currency.code] ?? 'xx') + ' fis rounded text-xl'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "excel-card-title"
                      },
                      "text": "{{currency.code}}"
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "text-tertiary"
                      },
                      "text": "{{(typeof currency.name === 'object' ? $localized(currency.name) : currency.name) + (currency.code === (_local.form?.language_currency?.default_currency ?? 'KRW') ? ' (' + $t('sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.default_label') + ')' : '')}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "if": "{{_local.editingCurrencyIdx === currency._idx}}",
              "props": {
                "className": "flex flex-col gap-2 flex-1"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "pencil",
                        "className": "w-5 h-5 text-blue-500 dark:text-blue-400"
