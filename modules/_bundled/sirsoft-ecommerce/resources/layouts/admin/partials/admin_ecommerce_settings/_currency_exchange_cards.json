                {
                  "type": "composite",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "{{'language_currency.currencies.' + currency._idx + '.decimal_places'}}",
                    "value": "{{currency.decimal_places ?? 0}}",
                    "min": 0,
                    "max": 8,
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            }
          ]
        }
      ]
