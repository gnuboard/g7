                    "placeholder": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.new_currency.code_placeholder",
                    "className": "{{_local.editingCurrency?.hasError ? 'input uppercase border-red-500 dark:border-red-500 focus:border-red-500 focus:ring-red-500' : 'input uppercase'}}",
                    "maxLength": "3",
                    "disabled": "{{_computed.isReadOnly}}"
                  },
                  "actions": [
                    {
                      "type": "input",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "editingCurrency.hasError": false
                      }
                    }
                  ]
                },
                {
                  "type": "composite",
                  "name": "MultilingualInput",
                  "props": {
