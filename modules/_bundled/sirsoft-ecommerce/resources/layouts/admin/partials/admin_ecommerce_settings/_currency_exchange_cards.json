                        "className": "text-label-subtle whitespace-nowrap"
                      },
                      "text": "{{(_local.form?.language_currency?.default_currency ?? 'KRW') + ' 1,000 ='}}"
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "newCurrency.exchange_rate",
                        "value": "{{_local.form?.newCurrency?.exchange_rate ?? 1}}",
                        "className": "input flex-1 text-center",
                        "placeholder": "1.00",
                        "disabled": "{{_computed.isReadOnly}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-label-subtle"
                      },
                      "text": "{{_local.form?.newCurrency?.code || '???'}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_unit"
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "newCurrency.rounding_unit",
                    "value": "{{_local.form?.newCurrency?.rounding_unit ?? '0.01'}}",
                    "options": [
                      {
                        "value": "0.01",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.0_01"
                      },
                      {
                        "value": "0.1",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.0_1"
                      },
                      {
                        "value": "1",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_units.1"
                      }
                    ],
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_method"
                },
                {
                  "type": "composite",
                  "name": "Select",
                  "props": {
                    "name": "newCurrency.rounding_method",
                    "value": "{{_local.form?.newCurrency?.rounding_method ?? 'round'}}",
                    "options": [
                      {
                        "value": "floor",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.floor"
                      },
                      {
                        "value": "round",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.round"
                      },
                      {
                        "value": "ceil",
                        "label": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.rounding_methods.ceil"
                      }
                    ],
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "form-group"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "form-label"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.settings.language_currency.exchange_settings.decimal_places"
                },
                {
                  "type": "composite",
                  "name": "Input",
                  "props": {
                    "type": "number",
                    "name": "newCurrency.decimal_places",
                    "value": "{{_local.form?.newCurrency?.decimal_places ?? 2}}",
                    "min": 0,
                    "max": 8,
                    "className": "w-full",
                    "disabled": "{{_computed.isReadOnly}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
