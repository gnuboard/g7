{
  "meta": {
    "is_partial": true,
    "description": "Product Form - Delete Confirmation Modal"
  },
  "id": "modal_delete_confirm",
  "type": "composite",
  "name": "Modal",
  "props": {
    "title": "$t:sirsoft-ecommerce.admin.product.modal.delete.title",
    "size": "sm"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "text-center"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "triangle-exclamation",
                "className": "w-8 h-8 text-red-500 dark:text-red-400"
              }
            }
          ]
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-lg font-medium text-gray-900 dark:text-white mb-2"
          },
          "text": "$t:sirsoft-ecommerce.admin.product.modal.delete.confirm_question"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "bg-gray-50 dark:bg-gray-800 rounded-lg p-3 mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center justify-center gap-3"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{_local.form.images?.length > 0}}",
                  "props": {
                    "className": "w-10 h-10 rounded-lg overflow-hidden flex-shrink-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Img",
                      "props": {
                        "src": "{{_local.form.images?.[0]?.download_url}}",
                        "alt": "",
                        "className": "w-full h-full object-cover"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "if": "{{!_local.form.images?.length}}",
                  "props": {
                    "className": "w-10 h-10 rounded-lg bg-gray-200 dark:bg-gray-700 flex items-center justify-center flex-shrink-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Icon",
                      "props": {
                        "name": "image",
                        "className": "w-5 h-5 text-gray-400 dark:text-gray-500"
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-left"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "font-medium text-gray-900 dark:text-white text-sm"
                      },
                      "text": "{{$localized(_local.form.name)}}"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "props": {
                        "className": "text-xs text-gray-500 dark:text-gray-400"
                      },
                      "text": "{{_local.form.product_code ?? ''}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm text-gray-500 dark:text-gray-400"
          },
          "text": "$t:sirsoft-ecommerce.admin.product.modal.delete.warning_message"
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "mt-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-3"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-start gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "exclamation-circle",
                    "className": "w-4 h-4 text-yellow-600 dark:text-yellow-400 flex-shrink-0 mt-0.5"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "props": {
                    "className": "text-sm text-yellow-700 dark:text-yellow-300 text-left"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product.modal.delete.permanent_warning"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-end gap-3 mt-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
          },
          "actions": [
            {
              "type": "click",
              "handler": "closeModal",
              "target": "modal_delete_confirm"
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.common.cancel"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed"
          },
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "params": {
                "actions": [
                  {
                    "handler": "closeModal",
                    "target": "modal_delete_confirm"
                  },
                  {
                    "handler": "setState",
                    "params": { "target": "global", "ui.isDeleting": true }
                  },
                  {
                    "handler": "apiCall",
                    "auth_required": true,
                    "target": "/api/modules/sirsoft-ecommerce/admin/products/{{route.itemCode}}",
                    "params": {
                      "method": "DELETE"
                    },
                    "onSuccess": [
                      {
                        "handler": "setState",
                        "params": { "target": "global", "ui.isDeleting": false }
                      },
                      {
                        "handler": "toast",
                        "params": {
                          "type": "success",
                          "message": "$t:sirsoft-ecommerce.admin.product.messages.deleted_success"
                        }
                      },
                      {
                        "handler": "navigate",
                        "params": {
                          "url": "/admin/ecommerce/products"
                        }
                      }
                    ],
                    "onError": [
                      {
                        "handler": "setState",
                        "params": { "target": "global", "ui.isDeleting": false }
                      },
                      {
                        "handler": "toast",
                        "params": {
                          "type": "error",
                          "message": "{{$error.message ?? '$t:sirsoft-ecommerce.admin.product.messages.deleted_error'}}"
                        }
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:sirsoft-ecommerce.admin.product.modal.delete.confirm_button"
            }
          ]
        }
      ]
    }
  ]
}
