{
  "meta": {
    "is_partial": true,
    "description": "Product Form - Product Information Notice Section"
  },
  "id": "section_product_notice",
  "type": "basic",
  "name": "Section",
  "props": {
    "id": "notice",
    "className": "scroll-mt-32"
  },
  "children": [
    {
      "id": "notice_card",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "card-accordion mb-6"
      },
      "children": [
        {
          "id": "notice_header",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card-accordion-header"
          },
          "actions": [
            {
              "type": "click",
              "handler": "setState",
              "params": { "target": "local", "ui.noticeExpanded": "{{!_local.ui.noticeExpanded}}" }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "clipboard-list",
                    "className": "w-5 h-5 text-gray-500 dark:text-gray-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "card-accordion-title"
                  },
                  "text": "$t:sirsoft-ecommerce.admin.product.sections.notice"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm text-gray-500 dark:text-gray-400 ml-2"
                  },
                  "text": "({{(_local.form.notice_items ?? []).length}}$t:sirsoft-ecommerce.admin.product.notice.items_count_suffix)"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "chevron-down",
                "className": "card-accordion-icon transition-transform duration-200 {{_local.ui.noticeExpanded !== false ? 'rotate-180' : ''}}"
              }
            }
          ]
        },
        {
          "id": "notice_body",
          "type": "basic",
          "name": "Div",
          "if": "{{_local.ui.noticeExpanded !== false}}",
          "props": {
            "className": "card-accordion-body p-6 space-y-6"
          },
          "children": [
            {
              "id": "notice_existing_template_mode",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-4"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center justify-between"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "flex flex-col gap-2"
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-sm font-medium text-gray-700 dark:text-gray-300"
                      },
                      "text": "$t:sirsoft-ecommerce.admin.product.fields.notice_template"
                    },
                    {
                      "type": "basic",
                      "name": "A",
                      "props": {
                        "href": "/admin/ecommerce/product-notices",
                        "target": "_blank",
                        "rel": "noopener noreferrer",
                        "className": "btn btn-outline text-xs"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": {
                            "name": "arrow-up-right-from-square",
                            "className": "w-3 h-3 mr-1.5"
                          }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:sirsoft-ecommerce.admin.product.buttons.manage_notice_template"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Select",
                  "props": {
                    "className": "select w-full",
                    "value": "{{_global.pendingNoticeTemplateId ?? _local.ui.selectedNoticeTemplateId ?? ''}}",
                    "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "sirsoft-ecommerce.confirmSelectNoticeTemplate",
                      "params": {
                        "templateId": "{{parseInt($event.target.value) || null}}"
                      }
                    }
                  ],
                  "children": [
                    {
                      "type": "basic",
                      "name": "Option",
                      "props": {
                        "value": ""
                      },
                      "text": "$t:sirsoft-ecommerce.admin.product.placeholders.notice_template"
                    },
                    {
                      "type": "basic",
                      "name": "Option",
                      "iteration": {
                        "source": "{{notice_templates?.data?.data ?? []}}",
                        "item_var": "template",
                        "index_var": "tplIdx"
                      },
                      "props": {
                        "value": "{{template.id}}"
                      },
                      "text": "{{$localized(template.name)}}"
                    }
                  ]
                }
              ]
            },
            {
              "id": "notice_items_section",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "space-y-4"
              },
              "onComponentEvent": [
                {
                  "event": "notice:productBulkChangeConfirmed",
                  "handler": "sirsoft-ecommerce.fillNoticeItemsWithDetailReference",
                  "params": {
                    "form": "{{_eventData.form}}"
                  }
                }
              ],
              "children": [
                {
                  "id": "notice_items_header",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center justify-between"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "flex flex-col gap-3"
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-sm font-medium text-gray-700 dark:text-gray-300"
                          },
                          "text": "$t:sirsoft-ecommerce.admin.product.notice.items_list"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "px-2 py-0.5 bg-gray-200 dark:bg-gray-600 rounded text-xs text-gray-600 dark:text-gray-300"
                          },
                          "text": "{{(_local.form.notice_items ?? []).length}}$t:sirsoft-ecommerce.admin.product.notice.items_count_suffix"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex items-center gap-2"
                      },
                      "responsive": {
                        "portable": {
                          "props": {
                            "className": "flex flex-col w-full gap-2"
                          }
                        }
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Button",
                          "props": {
                            "type": "button",
                            "className": "px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed",
                            "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                          },
                          "responsive": {
                            "portable": {
                              "props": {
                                "className": "flex items-center justify-center w-full px-4 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                              }
                            }
                          },
                          "actions": [
                            {
                              "type": "click",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "global",
                                    "tempFormForBulkChange": "{{_local.form}}"
                                  }
                                },
                                {
                                  "handler": "openModal",
                                  "target": "notice_bulk_change_modal"
                                }
                              ]
                            }
                          ],
                          "text": "$t:sirsoft-ecommerce.admin.product.notice.fill_detail_ref"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "notice_locale_panel",
                  "type": "composite",
                  "name": "MultilingualTabPanel",
                  "props": {
                    "variant": "underline",
                    "className": "mb-4"
                  },
                  "children": [
                    {
                      "id": "notice_items_editor",
                      "type": "composite",
                      "name": "DynamicFieldList",
                      "props": {
                        "name": "notice_items",
                        "items": "{{_local.form.notice_items ?? []}}",
                        "itemIdKey": "key",
                        "errors": "{{_local.errors}}",
                        "columns": [
                          {
                            "key": "name",
                            "type": "multilingual",
                            "label": "$t:sirsoft-ecommerce.admin.product.notice.col_name"
                          },
                          {
                            "key": "content",
                            "type": "multilingual",
                            "label": "$t:sirsoft-ecommerce.admin.product.notice.col_value",
                            "placeholder": "$t:sirsoft-ecommerce.admin.product.notice.input_placeholder"
                          }
                        ],
                        "enableDrag": true,
                        "showIndex": true,
                        "minItems": 0,
                        "addLabel": "$t:sirsoft-ecommerce.admin.product.notice.add_item",
                        "emptyMessage": "$t:sirsoft-ecommerce.admin.product.notice.empty_message",
                        "disabled": "{{route.itemCode && product?.data?.abilities?.can_update !== true}}"
                      },
                      "actions": [
                        {
                          "event": "onChange",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "form.notice_items": "{{$args[0]}}"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
